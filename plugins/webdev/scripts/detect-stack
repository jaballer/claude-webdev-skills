#!/usr/bin/env python3
"""
Detect a web project's stack and resolve the commands other webdev skills run.

Outputs a JSON stack profile. When called with --key <name>, prints only that
command value. This is used by scripts/resolve-command.

Resolution order:
1. .claude/webdev.json overrides are authoritative.
2. Detected values fill any missing keys.
3. commandPrefix is prepended to detected commands only, never to pinned ones.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import sys
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple

# Prefer the stdlib tomllib (Python 3.11+). Fall back to a tiny subset parser for
# older versions — we only need simple key/value and [section] detection.
try:
    import tomllib
    HAS_TOMLLIB = True
except Exception:  # pragma: no cover
    tomllib = None  # type: ignore
    HAS_TOMLLIB = False

DEFAULT_BRANCH_PREFIXES = ["feature", "fix", "refactor", "docs", "chore", "review"]


def load_json(path: Path) -> Optional[Any]:
    try:
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return None


def load_toml(path: Path) -> Optional[Dict[str, Any]]:
    if HAS_TOMLLIB:
        try:
            with open(path, "rb") as f:
                return tomllib.load(f)
        except Exception:
            return None
    return parse_basic_toml(path)


def parse_basic_toml(path: Path) -> Optional[Dict[str, Any]]:
    """Tiny TOML parser sufficient for pyproject.toml header checks."""
    data: Dict[str, Any] = {}
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except Exception:
        return None
    section: Any = data
    for raw in text.splitlines():
        line = raw.split("#", 1)[0].strip()
        if not line:
            continue
        m = re.match(r"^\[(.+)\]$", line)
        if m:
            keys = [k.strip().strip('"') for k in m.group(1).split(".")]
            section = data
            for k in keys:
                section.setdefault(k, {})
                section = section[k]
            continue
        if re.match(r"^\[\[.\]\]$", line):
            section = data
            continue
        if "=" in line:
            key, value = line.split("=", 1)
            key = key.strip().strip('"')
            value = value.strip().strip('"').strip("'")
            if re.fullmatch(r"true|yes|on", value, re.I):
                value = True
            elif re.fullmatch(r"false|no|off", value, re.I):
                value = False
            elif re.fullmatch(r"\d+", value):
                value = int(value)
            section[key] = value
    return data


def find(root: Path, *names: str) -> Optional[Path]:
    for name in names:
        p = root / name
        if p.exists():
            return p
    return None


def find_any(root: Path, patterns: List[str]) -> Optional[Path]:
    for pat in patterns:
        found = list(root.glob(pat))
        if found:
            return found[0]
    return None


def package_json(root: Path) -> Optional[Dict[str, Any]]:
    return load_json(root / "package.json")


def package_manager_and_install(root: Path, overrides: Dict[str, Any]) -> Tuple[str, str]:
    """Return (package_manager, install_command) detected from lockfiles."""
    if root.joinpath("pnpm-lock.yaml").exists():
        return "pnpm", "pnpm install"
    if root.joinpath("yarn.lock").exists():
        return "yarn", "yarn install"
    if root.joinpath("bun.lock").exists() or root.joinpath("bun.lockb").exists():
        return "bun", "bun install"
    if root.joinpath("package-lock.json").exists():
        return "npm", "npm install"
    if root.joinpath("composer.lock").exists() or root.joinpath("composer.json").exists():
        return "composer", "composer install"
    if root.joinpath("poetry.lock").exists():
        return "poetry", "poetry install"
    if root.joinpath("uv.lock").exists():
        return "uv", "uv sync"
    if root.joinpath("requirements.txt").exists():
        return "pip", "pip install -r requirements.txt"
    return "unknown", ""


def package_manager_exec(package_manager: str, command: str) -> str:
    """Return the command that runs a package binary in the detected manager."""
    if package_manager == "pnpm":
        return f"pnpm exec {command}"
    if package_manager == "npm":
        return f"npx {command}"
    if package_manager == "yarn":
        return f"yarn exec {command}"
    if package_manager == "bun":
        return f"bunx {command}"
    if package_manager == "composer":
        return f"./vendor/bin/{command}"
    if package_manager == "poetry":
        return f"poetry run {command}"
    if package_manager == "uv":
        return f"uv run {command}"
    return command


def package_manager_run(package_manager: str, script: str) -> str:
    """Return the command that runs a package.json / composer script."""
    if package_manager == "npm":
        return f"npm run {script}"
    if package_manager == "yarn":
        return f"yarn {script}"
    if package_manager == "bun":
        return f"bun run {script}"
    if package_manager == "composer":
        return f"composer {script}"
    return f"{package_manager} {script}"


def detect_framework(root: Path, pkg: Optional[Dict[str, Any]]) -> str:
    if pkg is not None:
        deps = {**pkg.get("dependencies", {}), **pkg.get("devDependencies", {})}
        for fw in [
            "next", "nuxt", "@remix-run/react", "astro", "@sveltejs/kit",
            "svelte", "vite", "react", "vue", "@nestjs/core", "express",
        ]:
            if fw in deps:
                return fw.replace("@remix-run/react", "remix").replace("@nestjs/core", "nestjs")
    if root.joinpath("composer.json").exists():
        composer = load_json(root / "composer.json") or {}
        if "laravel/framework" in composer.get("require", {}):
            return "laravel"
        if any(k.startswith("symfony/") for k in composer.get("require", {})):
            return "symfony"
    if root.joinpath("pyproject.toml").exists():
        pyproject = load_toml(root / "pyproject.toml") or {}
        deps = pyproject.get("project", {}).get("dependencies", [])
        if isinstance(deps, list):
            for d in deps:
                if d.startswith("django"):
                    return "django"
                if d.startswith("flask"):
                    return "flask"
                if d.startswith("fastapi"):
                    return "fastapi"
    if find(root, "requirements.txt"):
        req = (root / "requirements.txt").read_text(encoding="utf-8", errors="ignore")
        for name in ["django", "flask", "fastapi"]:
            if re.search(rf"^{name}\b", req, re.M | re.I):
                return name
    return ""


def run_script_or(pkg: Optional[Dict[str, Any]], package_manager: str, script: str, fallback: str) -> str:
    scripts = (pkg or {}).get("scripts", {})
    if script in scripts:
        return package_manager_run(package_manager, script)
    return fallback


def js_test(pkg: Optional[Dict[str, Any]], package_manager: str, root: Path) -> Tuple[str, str]:
    scripts = (pkg or {}).get("scripts", {})
    if "test" in scripts:
        return package_manager_run(package_manager, "test"), "package.json"
    if find_any(root, ["vitest.config.*", "vitest.workspace.*"]):
        return f"{package_manager_exec(package_manager, 'vitest')} --run", "vitest.config"
    if find_any(root, ["jest.config.*", "jest.config.js", "jest.config.ts"]):
        return package_manager_exec(package_manager, "jest"), "jest.config"
    if find_any(root, ["playwright.config.*"]):
        return f"{package_manager_exec(package_manager, 'playwright')} test", "playwright.config"
    deps = set((pkg or {}).get("dependencies", {}).keys()) | set((pkg or {}).get("devDependencies", {}).keys())
    if "vitest" in deps:
        return f"{package_manager_exec(package_manager, 'vitest')} --run", "package.json"
    if "jest" in deps:
        return package_manager_exec(package_manager, "jest"), "package.json"
    if "playwright" in deps or "@playwright/test" in deps:
        return f"{package_manager_exec(package_manager, 'playwright')} test", "package.json"
    return "", ""


def _js_deps(pkg: Optional[Dict[str, Any]]) -> set[str]:
    return set((pkg or {}).get("dependencies", {}).keys()) | set((pkg or {}).get("devDependencies", {}).keys())


def js_format(pkg: Optional[Dict[str, Any]], package_manager: str, root: Path) -> Tuple[str, str]:
    scripts = (pkg or {}).get("scripts", {})
    if "format" in scripts:
        return package_manager_run(package_manager, "format"), "package.json"
    if find(root, "biome.json"):
        return f"{package_manager_exec(package_manager, 'biome')} format --write", "biome.json"
    if find(root, "prettier.config.js") or find_any(root, [".prettierrc*", "prettier.config.*"]):
        return f"{package_manager_exec(package_manager, 'prettier')} --write .", ".prettierrc"
    if "prettier" in _js_deps(pkg):
        return f"{package_manager_exec(package_manager, 'prettier')} --write .", "package.json"
    if "eslint" in _js_deps(pkg):
        return f"{package_manager_exec(package_manager, 'eslint')} --fix .", "package.json"
    return "", ""


def js_lint(pkg: Optional[Dict[str, Any]], package_manager: str, root: Path, format_cmd: str) -> Tuple[str, str]:
    scripts = (pkg or {}).get("scripts", {})
    if "lint" in scripts:
        return package_manager_run(package_manager, "lint"), "package.json"
    if find(root, "biome.json"):
        return f"{package_manager_exec(package_manager, 'biome')} check", "biome.json"
    eslint = find_any(root, [".eslintrc*", "eslint.config.*"])
    if eslint:
        return f"{package_manager_exec(package_manager, 'eslint')} .", str(eslint.name)
    if "eslint" in _js_deps(pkg):
        return f"{package_manager_exec(package_manager, 'eslint')} .", "package.json"
    prettier = find_any(root, [".prettierrc*", "prettier.config.*"])
    if prettier and not find(root, "biome.json"):
        return f"{package_manager_exec(package_manager, 'prettier')} --check .", str(prettier.name)
    if "prettier" in _js_deps(pkg):
        return f"{package_manager_exec(package_manager, 'prettier')} --check .", "package.json"
    return "", ""


def js_typecheck(pkg: Optional[Dict[str, Any]], package_manager: str, root: Path, framework: str) -> Tuple[str, str]:
    scripts = (pkg or {}).get("scripts", {})
    for key in ["typecheck", "type-check"]:
        if key in scripts:
            return package_manager_run(package_manager, key), "package.json"
    if not find(root, "tsconfig.json"):
        return "", ""
    if framework == "vue":
        return f"{package_manager_exec(package_manager, 'vue-tsc')} --noEmit", "tsconfig.json"
    if framework == "astro":
        return f"{package_manager_exec(package_manager, 'astro')} check", "tsconfig.json"
    return f"{package_manager_exec(package_manager, 'tsc')} --noEmit", "tsconfig.json"


def js_dev(pkg: Optional[Dict[str, Any]], package_manager: str, root: Path, framework: str) -> Tuple[str, str]:
    scripts = (pkg or {}).get("scripts", {})
    if "dev" in scripts:
        return package_manager_run(package_manager, "dev"), "package.json"
    if framework == "next":
        return f"{package_manager_exec(package_manager, 'next')} dev", "framework"
    if framework == "nuxt":
        return f"{package_manager_exec(package_manager, 'nuxt')} dev", "framework"
    if framework == "astro":
        return f"{package_manager_exec(package_manager, 'astro')} dev", "framework"
    if framework == "remix":
        return f"{package_manager_exec(package_manager, 'remix')} dev", "framework"
    if find_any(root, ["vite.config.*"]):
        return f"{package_manager_exec(package_manager, 'vite')}", "vite.config"
    return "", ""


def js_build(pkg: Optional[Dict[str, Any]], package_manager: str, root: Path, framework: str) -> Tuple[str, str]:
    scripts = (pkg or {}).get("scripts", {})
    if "build" in scripts:
        return package_manager_run(package_manager, "build"), "package.json"
    if framework == "next":
        return f"{package_manager_exec(package_manager, 'next')} build", "framework"
    if framework == "nuxt":
        return f"{package_manager_exec(package_manager, 'nuxt')} build", "framework"
    if framework == "astro":
        return f"{package_manager_exec(package_manager, 'astro')} build", "framework"
    if find_any(root, ["vite.config.*"]):
        return f"{package_manager_exec(package_manager, 'vite')} build", "vite.config"
    return "", ""


def php_test(root: Path, package_manager: str) -> Tuple[str, str]:
    if find(root, "phpunit.xml") or find(root, "phpunit.xml.dist"):
        return "./vendor/bin/phpunit", "phpunit.xml"
    if find(root, "pest.php"):
        return "./vendor/bin/pest", "pest.php"
    return "", ""


def php_format(root: Path, package_manager: str) -> Tuple[str, str]:
    if find(root, "pint.json") or find(root, "pint.json") or root.joinpath("composer.json").exists():
        composer = load_json(root / "composer.json") or {}
        if "laravel/framework" in composer.get("require", {}):
            return "./vendor/bin/pint", "laravel"
    if find_any(root, [".php-cs-fixer*", ".php-cs-fixer.dist.*"]):
        return "./vendor/bin/php-cs-fixer fix", ".php-cs-fixer"
    return "", ""


def php_lint(root: Path, package_manager: str, format_cmd: str) -> Tuple[str, str]:
    if find(root, "pint.json") or root.joinpath("composer.json").exists():
        composer = load_json(root / "composer.json") or {}
        if "laravel/framework" in composer.get("require", {}):
            return "./vendor/bin/pint --test", "laravel"
    if find_any(root, [".php-cs-fixer*", ".php-cs-fixer.dist.*"]):
        return "./vendor/bin/php-cs-fixer fix --dry-run", ".php-cs-fixer"
    if find(root, "phpstan.neon") or find(root, "phpstan.neon.dist"):
        return "./vendor/bin/phpstan analyse", "phpstan.neon"
    if find(root, "psalm.xml"):
        return "./vendor/bin/psalm", "psalm.xml"
    return "", ""


def php_typecheck(root: Path, package_manager: str) -> Tuple[str, str]:
    if find(root, "phpstan.neon") or find(root, "phpstan.neon.dist"):
        return "./vendor/bin/phpstan analyse", "phpstan.neon"
    if find(root, "psalm.xml"):
        return "./vendor/bin/psalm", "psalm.xml"
    return "", ""


def php_dev(root: Path, framework: str) -> Tuple[str, str]:
    if framework == "laravel":
        return "php artisan serve", "framework"
    return "", ""


def php_build(root: Path, framework: str) -> Tuple[str, str]:
    return "", ""


def python_test(root: Path, package_manager: str) -> Tuple[str, str]:
    if find(root, "pytest.ini") or find(root, "setup.cfg") or root.joinpath("pyproject.toml").exists():
        pyproject = load_toml(root / "pyproject.toml") or {}
        if "pytest" in pyproject.get("project", {}).get("dependencies", []) or pyproject.get("tool", {}).get("pytest"):
            return package_manager_exec(package_manager, "pytest"), "pytest.ini"
    if find(root, "tests"):
        return package_manager_exec(package_manager, "pytest"), "tests/"
    return "", ""


def python_format(root: Path, package_manager: str) -> Tuple[str, str]:
    if find(root, "ruff.toml") or root.joinpath("pyproject.toml").exists():
        pyproject = load_toml(root / "pyproject.toml") or {}
        if pyproject.get("tool", {}).get("ruff"):
            return f"{package_manager_exec(package_manager, 'ruff')} format .", "ruff.toml"
    if root.joinpath("pyproject.toml").exists():
        pyproject = load_toml(root / "pyproject.toml") or {}
        if pyproject.get("tool", {}).get("black"):
            return f"{package_manager_exec(package_manager, 'black')} .", "black"
    return "", ""


def python_lint(root: Path, package_manager: str) -> Tuple[str, str]:
    if find(root, "ruff.toml") or root.joinpath("pyproject.toml").exists():
        pyproject = load_toml(root / "pyproject.toml") or {}
        if pyproject.get("tool", {}).get("ruff"):
            return f"{package_manager_exec(package_manager, 'ruff')} check .", "ruff.toml"
    if find(root, "mypy.ini") or root.joinpath("pyproject.toml").exists():
        pyproject = load_toml(root / "pyproject.toml") or {}
        if pyproject.get("tool", {}).get("mypy"):
            return package_manager_exec(package_manager, "mypy"), "mypy.ini"
    if find(root, "pyrightconfig.json"):
        return package_manager_exec(package_manager, "pyright"), "pyrightconfig.json"
    return "", ""


def python_typecheck(root: Path, package_manager: str) -> Tuple[str, str]:
    if find(root, "mypy.ini") or root.joinpath("pyproject.toml").exists():
        pyproject = load_toml(root / "pyproject.toml") or {}
        if pyproject.get("tool", {}).get("mypy"):
            return package_manager_exec(package_manager, "mypy"), "mypy.ini"
    if find(root, "pyrightconfig.json"):
        return package_manager_exec(package_manager, "pyright"), "pyrightconfig.json"
    return "", ""


def python_dev(root: Path, framework: str) -> Tuple[str, str]:
    if framework == "django":
        return "python manage.py runserver", "framework"
    if framework == "flask":
        return "flask run", "framework"
    return "", ""


def python_build(root: Path, framework: str) -> Tuple[str, str]:
    return "", ""


def migration_command(root: Path, package_manager: str, framework: str) -> Tuple[str, str]:
    if framework == "laravel":
        return "php artisan migrate:status", "framework"
    if framework == "django":
        return f"{package_manager_exec(package_manager, 'python')} manage.py showmigrations", "framework"
    if framework == "next" and find(root, "prisma"):
        return f"{package_manager_exec(package_manager, 'prisma')} migrate status", "prisma"
    return "", ""


def detect_workspace(root: Path, pkg: Optional[Dict[str, Any]]) -> str:
    if root.joinpath("pnpm-workspace.yaml").exists():
        return "pnpm-workspace"
    if root.joinpath("turbo.json").exists():
        return "turbo"
    if root.joinpath("nx.json").exists():
        return "nx"
    if root.joinpath("lerna.json").exists():
        return "lerna"
    if pkg and isinstance(pkg.get("workspaces"), (list, dict)):
        return "package.json"
    return ""


def default_branch(root: Path) -> str:
    try:
        import subprocess
        result = subprocess.run(
            ["git", "symbolic-ref", "refs/remotes/origin/HEAD"],
            capture_output=True, text=True, cwd=str(root)
        )
        if result.returncode == 0 and result.stdout:
            return result.stdout.strip().split("/")[-1]
        for branch in ["main", "master"]:
            result = subprocess.run(
                ["git", "rev-parse", "--verify", branch],
                capture_output=True, cwd=str(root)
            )
            if result.returncode == 0:
                return branch
    except Exception:
        pass
    return "main"


def merge_method(root: Path) -> str:
    try:
        import subprocess
        result = subprocess.run(
            ["git", "config", "--get", "merge.ff"],
            capture_output=True, text=True, cwd=str(root)
        )
        if result.returncode == 0 and result.stdout.strip() == "false":
            return "merge"
    except Exception:
        pass
    return "squash"


def apply_prefix(command: str, prefix: str) -> str:
    if not prefix or not command:
        return command
    return f"{prefix} {command}"


def detect(root: Path, overrides: Dict[str, Any]) -> Dict[str, Any]:
    pkg = package_json(root)
    pm, install = package_manager_and_install(root, overrides)
    framework = detect_framework(root, pkg)

    gaps: List[str] = []

    if "packageManager" in overrides:
        pm = overrides["packageManager"]
    if "install" in overrides:
        install = overrides["install"]

    if pm in ("unknown", ""):
        gaps.append("No supported lockfile or package manager found.")

    if pm in ("pnpm", "npm", "yarn", "bun"):
        test, test_src = js_test(pkg, pm, root)
        fmt, fmt_src = js_format(pkg, pm, root)
        lint, lint_src = js_lint(pkg, pm, root, fmt)
        typecheck, typecheck_src = js_typecheck(pkg, pm, root, framework)
        dev, dev_src = js_dev(pkg, pm, root, framework)
        build, build_src = js_build(pkg, pm, root, framework)
    elif pm == "composer":
        test, test_src = php_test(root, pm)
        fmt, fmt_src = php_format(root, pm)
        lint, lint_src = php_lint(root, pm, fmt)
        typecheck, typecheck_src = php_typecheck(root, pm)
        dev, dev_src = php_dev(root, framework)
        build, build_src = php_build(root, framework)
    elif pm in ("poetry", "uv", "pip"):
        test, test_src = python_test(root, pm)
        fmt, fmt_src = python_format(root, pm)
        lint, lint_src = python_lint(root, pm)
        typecheck, typecheck_src = python_typecheck(root, pm)
        dev, dev_src = python_dev(root, framework)
        build, build_src = python_build(root, framework)
    else:
        test = fmt = lint = typecheck = dev = build = ""
        test_src = fmt_src = lint_src = typecheck_src = dev_src = build_src = ""

    migration, migration_src = migration_command(root, pm, framework)
    workspace = detect_workspace(root, pkg)

    if not test:
        gaps.append("Could not determine a test runner.")

    defaults: Dict[str, Any] = {
        "packageManager": pm,
        "install": install,
        "test": test,
        "format": fmt,
        "lint": lint,
        "typecheck": typecheck,
        "dev": dev,
        "build": build,
        "framework": framework,
        "migration": migration,
        "workspace": workspace,
        "defaultBranch": default_branch(root),
        "mergeMethod": merge_method(root),
        "branchPrefixes": DEFAULT_BRANCH_PREFIXES,
        "commandPrefix": "",
    }

    sources: Dict[str, str] = {
        "packageManager": "detected" if pm != "unknown" else "",
        "install": "detected",
        "test": test_src,
        "format": fmt_src,
        "lint": lint_src,
        "typecheck": typecheck_src,
        "dev": dev_src,
        "build": build_src,
        "framework": "detected" if framework else "",
        "migration": migration_src,
        "workspace": "detected" if workspace else "",
        "defaultBranch": "detected",
        "mergeMethod": "detected",
        "branchPrefixes": "default",
        "commandPrefix": "",
    }

    resolved: Dict[str, Any] = {}
    for key in defaults:
        if key in overrides:
            resolved[key] = overrides[key]
            sources[key] = "webdev.json"
        else:
            resolved[key] = defaults[key]

    command_prefix = resolved.get("commandPrefix", "")
    # Prefix applies to detected commands, not to pinned ones.
    command_keys = ["install", "test", "format", "lint", "typecheck", "dev", "build", "migration"]
    for key in command_keys:
        if sources[key] != "webdev.json" and resolved.get(key):
            resolved[key] = apply_prefix(resolved[key], command_prefix)

    resolved["gaps"] = gaps
    resolved["sources"] = sources
    resolved["webdevJsonPath"] = str((root / ".claude" / "webdev.json").resolve()) if (root / ".claude" / "webdev.json").exists() else None
    return resolved


def main() -> None:
    parser = argparse.ArgumentParser(description="Detect a web project stack and output a JSON profile.")
    parser.add_argument("--root", default=None, help="Project root directory (default: current directory)")
    parser.add_argument("--key", default=None, help="Print only the value for this key")
    args = parser.parse_args()

    root = Path(args.root).resolve() if args.root else Path.cwd()

    webdev_path = root / ".claude" / "webdev.json"
    overrides: Dict[str, Any] = load_json(webdev_path) or {}

    profile = detect(root, overrides)

    if args.key:
        value = profile.get(args.key)
        if value is None:
            print(f"detect-stack: unknown key {args.key!r}", file=sys.stderr)
            sys.exit(1)
        if isinstance(value, (list, dict, bool, type(None))):
            print(json.dumps(value), flush=True)
        else:
            print(value, flush=True)
        return

    print(json.dumps(profile, indent=2), flush=True)


if __name__ == "__main__":
    main()
